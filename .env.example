# Copy this file to .env and fill in your actual token
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Database configuration (SQLite)
DB_PATH=database.sqlite
# DB_SYNCHRONIZE=false  # Set to true to auto-create tables (use with caution in production)

# Node environment (production, development)
NODE_ENV=development

# Note: Reminder settings are now per-user and configurable via /settings command
# The following environment variables are no longer used (kept for backward compatibility):
# REMINDER_CRON="0 9 * * *"
# REMINDER_LIMIT=5