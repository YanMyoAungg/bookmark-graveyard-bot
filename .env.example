# Copy this file to .env and fill in your actual token
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Database configuration
# For local development (SQLite)
DB_TYPE=sqlite
DB_DATABASE=bookmarks.db

# For production (PostgreSQL on Render, Supabase, etc.)
# DB_TYPE=postgres
# DATABASE_URL=postgresql://user:password@host:port/database
# DB_SSL=true  # Set to false for local PostgreSQL
# DB_SYNCHRONIZE=false  # Set to true to auto-create tables (use with caution in production)

# Reminder schedule (cron expression)
REMINDER_CRON="0 9 * * *"  # 9 AM daily
REMINDER_LIMIT=5           # Max links per reminder

# Node environment (production, development)
NODE_ENV=development